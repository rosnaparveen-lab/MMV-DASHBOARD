<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Master Vehicle Database</h2>
    <div class="badge bg-primary fs-6">Total Records: <%= number_with_delimiter(@total_count) %></div>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="bg-light">
            <tr>
              <th class="px-4">Vehicle Name</th>
              <th>Insurance Code</th>
              <th>Vehicle Code</th>
              <th>Type</th>
              <th>Fuel</th>
              <th>CC</th>
              <th class="text-center">Capacity</th>
            </tr>
          </thead>
          <tbody>
            <% if @vehicles.any? %>
              <% @vehicles.each do |vehicle| %>
                <tr>
                  <td class="px-4 font-weight-bold"><%= vehicle.carrier_vehicle_name %></td>
                  <td><span class="badge bg-light text-dark border"><%= vehicle.insurance_code %></span></td>
                  <td><code><%= vehicle.vehicle_code %></code></td>
                  <td><%= vehicle.vehicle_type %></td>
                  <td><%= vehicle.fuel_type %></td>
                  <td><%= vehicle.cubic_capacity %></td>
                  <td class="text-center"><%= vehicle.seating_capacity %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="7" class="text-center py-5 text-muted">
                  <div class="mb-2">🚗</div>
                  No vehicles found in the database.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    
    <% if @pagy.pages > 1 %>
      <div class="card-footer bg-white py-3">
        <div class="d-flex justify-content-center">
          <%== pagy_nav(@pagy) %>
        </div>
      </div>
    <% end %>
  </div>
</div>
