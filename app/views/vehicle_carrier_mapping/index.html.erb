<style>
  .carrier-mapping-page {
    background: #f8fafc;
    padding: 32px 20px 48px;
    min-height: calc(100vh - 110px);
  }

  .carrier-mapping-card {
    max-width: 1400px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
    padding: 32px;
  }

  .carrier-mapping-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .carrier-mapping-title {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
  }

  .carrier-mapping-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .carrier-mapping-filters {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(220px, 1fr) minmax(220px, 1fr) auto auto;
    gap: 14px;
    align-items: end;
    margin-bottom: 14px;
  }

  .carrier-mapping-filters label {
    display: none;
  }

  .carrier-mapping-input,
  .carrier-mapping-select,
  .carrier-mapping-button {
    height: 44px;
    padding: 0 16px;
    border-radius: 12px;
    border: 1px solid #cbd5e1;
    background: #ffffff;
    font-size: 0.95rem;
    color: #0f172a;
    width: 100%;
  }

  .carrier-mapping-select {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, #0f172a 50%), linear-gradient(135deg, #0f172a 50%, transparent 50%);
    background-position: calc(100% - 20px) calc(50% - 2px), calc(100% - 15px) calc(50% - 2px);
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
  }

  .carrier-mapping-button {
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .btn-filter {
    background: #2563eb;
    color: #ffffff;
    border-color: transparent;
  }

  .btn-filter:hover {
    background: #1d4ed8;
  }

  .btn-clear {
    background: transparent;
    color: #334155;
    border: 1px solid #cbd5e1;
  }

  .btn-clear:hover {
    background: #f8fafc;
  }

  .btn-download {
    background: transparent;
    color: #0f172a;
    border: 1px solid #0f172a;
  }

  .btn-download:hover {
    background: #ecfdf5;
  }

  .btn-download .icon {
    margin-right: 8px;
  }

  .filters-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
    color: #475569;
    font-size: 0.95rem;
  }

  .filters-meta strong {
    color: #0f172a;
  }

  .vehicle-type-blocks {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .vehicle-type-block {
    padding: 20px;
    border-radius: 16px;
    background: #f8fafc;
    text-align: center;
    border: 1px solid #e2e8f0;
  }

  .vehicle-type-block h3 {
    margin: 0;
    font-size: 1.25rem;
    color: #0f172a;
  }

  .vehicle-type-block p {
    margin: 8px 0 0;
    color: #64748b;
  }

  .table-wrapper {
    overflow-x: auto;
    margin-bottom: 24px;
  }

  .carrier-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 900px;
  }

  .carrier-table th,
  .carrier-table td {
    padding: 14px 16px;
    border-bottom: 1px solid #e2e8f0;
    font-size: 0.95rem;
  }

  .carrier-table thead th {
    position: sticky;
    top: 0;
    background: #f1f5f9;
    color: #334155;
    font-weight: 700;
    text-align: left;
    z-index: 1;
  }

  .carrier-table tbody tr:nth-child(even) {
    background: #f8fafc;
  }

  .carrier-table tbody tr:hover {
    background: #e2e8f0;
  }

  .carrier-table td.numeric,
  .carrier-table th.numeric {
    text-align: center;
  }

  .empty-state {
    padding: 48px 0;
    text-align: center;
    color: #64748b;
    font-size: 1rem;
  }

  .loading-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .loading-overlay.show {
    display: flex;
  }

  .loading-box {
    background: #ffffff;
    padding: 28px;
    border-radius: 16px;
    min-width: 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .loading-spinner {
    width: 42px;
    height: 42px;
    border: 4px solid #e2e8f0;
    border-top-color: #2563eb;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 1100px) {
    .carrier-mapping-filters {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .carrier-mapping-filters {
      grid-template-columns: 1fr;
    }

    .carrier-mapping-header,
    .filters-meta {
      flex-direction: column;
      align-items: stretch;
    }

    .carrier-mapping-actions {
      justify-content: flex-start;
    }
  }
</style>

<div class="carrier-mapping-page">
  <div class="carrier-mapping-card">
    <div class="carrier-mapping-header">
      <h1 class="carrier-mapping-title">Carrier Mapping</h1>
      <div class="carrier-mapping-actions">
        <%= form_with url: export_vehicle_carrier_mapping_index_path, method: :get, local: true, id: "download-form", class: "d-inline" do |f| %>
          <%= hidden_field_tag :insurance_code, params[:insurance_code] %>
          <%= hidden_field_tag :vehicle_type, params[:vehicle_type] %>
          <%= hidden_field_tag :name, params[:name] %>
          <button type="submit" class="carrier-mapping-button btn-download" id="download-btn">
            <span class="icon">⬇</span> Download CSV
          </button>
        <% end %>
      </div>
    </div>

    <form method="get" action="<%= vehicles_vehicle_carrier_mapping_index_path %>" class="carrier-mapping-filters" id="filter-form">
      <input type="text" name="name" value="<%= params[:name] %>" class="carrier-mapping-input" placeholder="Search Carrier Vehicle Name">
      <select name="insurance_code" id="insurance_code" class="carrier-mapping-select">
        <option value="" <%= params[:insurance_code].blank? ? 'selected' : '' %>>Select Insurance Code</option>
        <% @insurances.each do |insurance| %>
          <option value="<%= insurance %>" <%= params[:insurance_code] == insurance ? 'selected' : '' %>><%= insurance %></option>
        <% end %>
      </select>
      <select name="vehicle_type" id="vehicle_type" class="carrier-mapping-select">
        <option value="" <%= params[:vehicle_type].blank? ? 'selected' : '' %>>Select Vehicle Type</option>
        <% @lob_mapping_hash.keys.each do |type| %>
          <option value="<%= type %>" <%= params[:vehicle_type] == type ? 'selected' : '' %>><%= type %></option>
        <% end %>
      </select>
      <button type="submit" class="carrier-mapping-button btn-filter">Filter</button>
      <%= link_to "Clear Filters", vehicles_vehicle_carrier_mapping_index_path, class: "carrier-mapping-button btn-clear" %>
    </form>

    <div class="filters-meta">
      <% total_records = @carrier_map_two_wheelers.respond_to?(:total_count) ? @carrier_map_two_wheelers.total_count : @carrier_map_two_wheelers.size %>
      <div>Showing <strong><%= @carrier_map_two_wheelers.size %></strong> of <strong><%= total_records %></strong> records</div>
      <div id="filter-loading-text" style="display: none; color: #2563eb; font-weight: 600;">Applying filters…</div>
    </div>

    <div class="vehicle-type-blocks">
      <% @lob_mapping_hash.each do |vehicle_type, count| %>
        <div class="vehicle-type-block">
          <h3><%= vehicle_type %></h3>
          <p><%= count %> vehicles</p>
        </div>
      <% end %>
    </div>

    <div class="table-wrapper">
      <% if @carrier_map_two_wheelers.empty? %>
        <div class="empty-state">No carrier mappings found. Try adjusting your filters.</div>
      <% else %>
        <table class="carrier-table">
          <thead>
            <tr>
              <th>Carrier Vehicle Name</th>
              <th>Insurance Code</th>
              <th>Vehicle Type</th>
              <th>Fuel Type</th>
              <th class="numeric">CC</th>
              <th class="numeric">Seating Capacity</th>
            </tr>
          </thead>
          <tbody>
            <% @carrier_map_two_wheelers.each do |mapping| %>
              <tr>
                <td><%= mapping.carrier_vehicle_name %></td>
                <td><%= mapping.insurance_code %></td>
                <td><%= mapping.vehicle_type %></td>
                <td><%= mapping.fuel_type %></td>
                <td class="numeric"><%= mapping.cubic_capacity %></td>
                <td class="numeric"><%= mapping.seating_capacity %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>

    <% if @carrier_map_two_wheelers.respond_to?(:total_pages) && @carrier_map_two_wheelers.total_pages > 1 %>
      <div class="pagination-container">
        <%= pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>
</div>

<div id="loading-overlay" class="loading-overlay">
  <div class="loading-box">
    <div class="loading-spinner"></div>
    <div id="loading-message">Generating CSV... This may take a few minutes for large datasets.</div>
  </div>
</div>

<script>
  document.getElementById('download-btn')?.addEventListener('click', function() {
    document.getElementById('loading-message').textContent = 'Generating CSV... This may take a few minutes for large datasets.';
    document.getElementById('loading-overlay').classList.add('show');
  });

  document.getElementById('filter-form')?.addEventListener('submit', function() {
    document.getElementById('filter-loading-text').style.display = 'block';
  });
</script>
