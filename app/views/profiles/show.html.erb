<style>
  .profile-page {
    background: #f8fafc;
    min-height: calc(100vh - 90px);
    padding: 40px 16px 60px;
  }

  .profile-card {
    max-width: 800px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    padding: 32px;
  }

  .profile-header {
    margin-bottom: 28px;
  }

  .profile-title {
    margin: 0;
    font-size: 2.25rem;
    font-weight: 700;
    color: #0f172a;
  }

  .profile-subtitle {
    margin: 12px 0 0;
    color: #64748b;
    font-size: 1rem;
    line-height: 1.6;
  }

  .profile-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px 32px;
    margin-bottom: 32px;
  }

  .profile-row {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-bottom: 18px;
    border-bottom: 1px solid #e2e8f0;
  }

  .profile-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .profile-label {
    margin: 0;
    color: #64748b;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .profile-value {
    margin: 0;
    color: #0f172a;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.7;
  }

  .profile-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: 999px;
    background: #e2e8f0;
    color: #0f172a;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: capitalize;
  }

  .profile-footer {
    margin-top: 20px;
  }

  .profile-back-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    background: #ffffff;
    color: #334155;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .profile-back-button:hover {
    background: #f8fafc;
    border-color: #94a3b8;
  }

  .profile-back-button .icon {
    font-size: 1rem;
  }

  @media (max-width: 720px) {
    .profile-card {
      padding: 24px;
    }

    .profile-details {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="profile-page">
  <div class="profile-card">
    <div class="profile-header">
      <h1 class="profile-title">My Profile</h1>
      <p class="profile-subtitle"><%= current_user.respond_to?(:name) && current_user.name.present? ? current_user.name : current_user.email %></p>
    </div>

    <div class="profile-details">
      <div class="profile-row">
        <p class="profile-label">Email Address</p>
        <p class="profile-value"><%= current_user.email %></p>
      </div>

      <div class="profile-row">
        <p class="profile-label">Role</p>
        <p class="profile-value"><span class="profile-badge"><%= (current_user.role || 'User').to_s.capitalize %></span></p>
      </div>

      <div class="profile-row">
        <p class="profile-label">Account Created</p>
        <p class="profile-value"><%= current_user.created_at.strftime('%-d %B %Y, %-I:%M %p') %></p>
      </div>
    </div>

    <div class="profile-footer">
      <%= link_to root_path, class: 'profile-back-button' do %>
        <span class="icon">←</span>
        Back to Dashboard
      <% end %>
    </div>
  </div>
</div>
