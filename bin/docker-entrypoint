#!/bin/bash
set -e

# Remove a potentially pre-existing server.pid for Rails.
if [ -f /app/tmp/pids/server.pid ]; then
  rm /app/tmp/pids/server.pid
fi

# If running the web server, prepare the database (optional, depending on your workflow)
# In production with an external MySQL, you might want to run migrations manually or via CI/CD,
# but rails db:prepare is safe to run as it only migrates if needed.
bundle exec rails db:prepare

# Then exec the container's main process (what's set as CMD in the Dockerfile).
exec "$@"
